APP_NAME=Aplikasi Pembelajaran ASD API
APP_ENV=production
APP_SECRET_KEY=change-this-to-a-long-random-string
DATABASE_SCHEMA=public

POSTGRES_DB=asd_learning_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

BACKEND_PORT=8000
FRONTEND_PORT=3000

# Replace with your VPS public IP or domain before building the frontend image.
FRONTEND_ORIGIN=http://YOUR_VPS_IP:3000
NEXT_PUBLIC_API_BASE_URL=http://YOUR_VPS_IP:8000/api

# Optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
